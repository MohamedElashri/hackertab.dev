{
  "manifest_version": 3,
  "name": "DevTab",
  "description": "Developer news from GitHub, Hacker News, Lobsters, and Reddit in your new tab. No tracking, no ads.",
  "version": "1.1.1",
  "author": "Mohamed Elashri",
  "homepage_url": "https://github.com/MohamedElashri/DevTab",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://api.github.com/*",
    "https://hacker-news.firebaseio.com/*",
    "https://lobste.rs/*",
    "https://www.reddit.com/*"
  ],
  "icons": {
    "16": "/logos/logo16.png",
    "32": "/logos/logo32.png",
    "48": "/logos/logo48.png",
    "128": "/logos/logo128.png"
  },
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "devtab@melashri.dev",
      "strict_min_version": "140.0",
      "android_strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  }
}
